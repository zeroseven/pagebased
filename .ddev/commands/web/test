#!/usr/bin/env bash

## Description: Run unit and/or functional tests with readiness checks
## Usage: test [flags]
## Example: "ddev test" or "ddev test --unit" or "ddev test --functional" or "ddev test --coverage"
## Flags: [{"Name":"unit","Shorthand":"u","Usage":"Run unit tests only"},{"Name":"functional","Shorthand":"f","Usage":"Run functional tests only"},{"Name":"coverage","Shorthand":"c","Usage":"Run tests with coverage report"},{"Name":"filter","Usage":"PHPUnit filter expression"}]

set -Eeuo pipefail

# Auto-proxy into DDEV if running outside the container
if [ -z "${IS_DDEV_PROJECT:-}" ]; then
    if command -v ddev >/dev/null 2>&1 && [ -d ".ddev" ]; then
        ddev exec bash -lc '/var/www/html/.ddev/commands/web/test "$@"' -- _ "$@"
        exit $?
    fi
fi

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; BLUE='\033[0;34m'; NC='\033[0m'
info()   { echo -e "${YELLOW}$*${NC}"; }
ok()     { echo -e "${GREEN}✓ $*${NC}"; }
err()    { echo -e "${RED}✗ $*${NC}"; }
header() { echo -e "${BLUE}━━━ $* ━━━${NC}"; }

RUN_UNIT=false; RUN_FUNCTIONAL=false; WITH_COVERAGE=false; FILTER=""

for arg in "$@"; do
    case $arg in
        --unit|-u)       RUN_UNIT=true ;;
        --functional|-f) RUN_FUNCTIONAL=true ;;
        --coverage|-c)   WITH_COVERAGE=true ;;
        --filter=*)      FILTER="${arg#*=}" ;;
        --help|-h)
            echo "Usage: ddev test [flags]"
            echo "  -u, --unit           Run unit tests only"
            echo "  -f, --functional     Run functional tests only"
            echo "  -c, --coverage       Run with coverage report"
            echo "      --filter=EXPR    PHPUnit --filter expression"
            echo ""
            echo "Without flags, both unit and functional tests are run."
            exit 0
            ;;
    esac
done

if [ "$RUN_UNIT" = false ] && [ "$RUN_FUNCTIONAL" = false ]; then
    RUN_UNIT=true; RUN_FUNCTIONAL=true
fi

echo ""; header "pagebased Test Runner"; echo ""

# Readiness: vendor
header "Readiness: Dependencies"
if [ ! -f "/var/www/html/.build/vendor/autoload.php" ]; then
    info "vendor not found — running composer install..."
    cd /var/www/html && composer install --no-interaction --no-progress
    ok "Dependencies installed"
else
    ok "Dependencies ready"
fi

# Readiness: database (only for functional tests)
if [ "$RUN_FUNCTIONAL" = true ]; then
    header "Readiness: Database"
    DB_READY=false
    for i in $(seq 1 15); do
        if mysqladmin ping -h db -u root -proot --silent 2>/dev/null; then
            DB_READY=true; break
        fi
        info "Waiting for database... ($i/15)"; sleep 2
    done
    if [ "$DB_READY" = false ]; then
        err "Database not reachable. Make sure DDEV is running: ddev start"; exit 1
    fi
    ok "Database reachable"
fi

# Readiness: TYPO3 test environment
header "Readiness: Test Environment"
if [ ! -d "/var/www/html/.build/public/typo3conf/ext/pagebased" ]; then
    info "Test environment not prepared — running post-autoload-dump..."
    cd /var/www/html && composer run-script post-autoload-dump || true
    ok "Test environment prepared"
else
    ok "Test environment ready"
fi

# Run tests
PHPUNIT="/var/www/html/.build/bin/phpunit"
FILTER_ARG="${FILTER:+--filter=$FILTER}"
EXIT_CODE=0

if [ "$RUN_UNIT" = true ]; then
    header "Unit Tests"
    if [ "$WITH_COVERAGE" = true ]; then
        "$PHPUNIT" -c /var/www/html/phpunit.unit.xml $FILTER_ARG || EXIT_CODE=$?
    else
        "$PHPUNIT" -c /var/www/html/phpunit.unit.xml --no-coverage $FILTER_ARG || EXIT_CODE=$?
    fi
fi

if [ "$RUN_FUNCTIONAL" = true ]; then
    header "Functional Tests"
    if [ "$WITH_COVERAGE" = true ]; then
        "$PHPUNIT" -c /var/www/html/phpunit.functional.xml $FILTER_ARG || EXIT_CODE=$?
    else
        "$PHPUNIT" -c /var/www/html/phpunit.functional.xml --no-coverage $FILTER_ARG || EXIT_CODE=$?
    fi
fi

echo ""
if [ $EXIT_CODE -eq 0 ]; then ok "All tests passed!"; else err "Tests failed (exit code $EXIT_CODE)"; fi
echo ""; exit $EXIT_CODE
